DEFAULT_TIMEZONE=America/Mexico_City

# Dograh Voice Lab
# Core
APP_ENV=local
APP_URL=http://localhost:3010
ENVIRONMENT=local
DEPLOYMENT_MODE=oss
AUTH_PROVIDER=local
BACKEND_API_ENDPOINT=http://localhost:8000
UI_APP_URL=http://localhost:3010
ENABLE_TELEMETRY=false

# Security
APP_SECRET=replace_me
BETTER_AUTH_SECRET=replace_me_if_required
JWT_SECRET=replace_me_if_required
OSS_JWT_SECRET=replace_me_for_local_only

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/postgres
REDIS_URL=redis://:redissecret@localhost:6379

# Storage
ENABLE_AWS_S3=false
MINIO_ENDPOINT=localhost:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=voice-audio
MINIO_SECURE=false

# LLM
OPENAI_API_KEY=replace_me
GEMINI_API_KEY=replace_me

# STT
STT_PROVIDER=replace_me
STT_API_KEY=replace_me
DEEPGRAM_API_KEY=replace_me

# TTS
TTS_PROVIDER=replace_me
TTS_API_KEY=replace_me
ELEVENLABS_API_KEY=replace_me

# Telephony
TELEPHONY_PROVIDER=mock
TWILIO_ACCOUNT_SID=replace_me
TWILIO_AUTH_TOKEN=replace_me
TWILIO_PHONE_NUMBER=replace_me
TURN_HOST=localhost
TURN_SECRET=replace_me
FORCE_TURN_RELAY=false

# n8n
N8N_WEBHOOK_URL=replace_me
N8N_WEBHOOK_SECRET=replace_me

# Google Calendar
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CLIENT_ID=replace_me
GOOGLE_CLIENT_SECRET=replace_me
GOOGLE_REFRESH_TOKEN=replace_me
GOOGLE_CALENDAR_ID=primary

# Observability
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
SENTRY_DSN=
LOG_LEVEL=DEBUG
